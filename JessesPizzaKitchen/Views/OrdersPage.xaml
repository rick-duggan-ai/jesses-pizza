<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dataControls="clr-namespace:Telerik.XamarinForms.DataControls;assembly=Telerik.XamarinForms.DataControls"
             xmlns:local="clr-namespace:JessesPizzaKitchen.Models;assembly=JessesPizzaKitchen"
             x:Class="JessesPizzaKitchen.Views.OrdersPage">
    <NavigationPage.TitleView>
        <StackLayout HorizontalOptions="End" VerticalOptions="Center" Spacing="10">
            <Label Style="{DynamicResource ConnectedIconStyle}"  >
                <Label.GestureRecognizers>
                    <TapGestureRecognizer
                Tapped="TapGestureRecognizer_Tapped"
                NumberOfTapsRequired="2" />
                </Label.GestureRecognizers>
            </Label>
        </StackLayout>
    </NavigationPage.TitleView>
    <ContentPage.Content>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width ="*"/>
                <ColumnDefinition Width ="*"/>
                <ColumnDefinition Width ="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Label FontSize="Large" HorizontalOptions="Center" Grid.Column="0" Grid.Row="0" Text="{Binding AuthorizedPaymentsGrouped.Count,StringFormat='Received, Count: {0:N0}'}"></Label>
            <Label FontSize="Large" HorizontalOptions="Center" Grid.Column="1" Grid.Row="0" Text="{Binding KitchenPaymentsGrouped.Count,StringFormat='In Kitchen, Count: {0:N0}'}"></Label>
            <Label FontSize="Large" HorizontalOptions="Center" Grid.Column="2" Grid.Row="0" Text="{Binding OutPaymentsGrouped.Count,StringFormat='Out for Delivery/Ready for Pickup, Count: {0:N0}'}"></Label>
            <Label FontSize="Large" HorizontalTextAlignment="Center" HorizontalOptions="Center" Grid.Column="3" Grid.Row="0" Text="{Binding DeliveredPaymentsGrouped.Count,StringFormat='Delivered/Picked Up, Count: {0:N0}'}"></Label>

            <ListView x:Name="PaymentsList" 
                  ItemsSource="{Binding AuthorizedPaymentsGrouped}" 
                  IsGroupingEnabled="True"
                  HasUnevenRows="True" Grid.Row="1" Grid.Column="0"
                  SelectionMode="None"
                      SeparatorVisibility="None">

                <ListView.GroupHeaderTemplate>
                    <DataTemplate>
                        <ViewCell Height="400" >
                            <StackLayout Grid.Row="0" Grid.Column="0" Orientation="Vertical"
                                     Padding="10"
                                     BackgroundColor="#3498DB" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand">
                                    <Label Text="{Binding Key.Name,StringFormat='Name: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.PhoneNumber,StringFormat='Phone Number: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.Address1,StringFormat='Address: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.City,StringFormat='City: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.ZipCode,StringFormat='Zip Code: {0:F0}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.Total,StringFormat='SubTotal: {0:C}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.Date,StringFormat='Order Time: {0:h:mm tt }'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.IsDelivery,StringFormat='Is Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.NoContact,StringFormat='Is No Contact Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Button Text="{Binding Key, Converter={StaticResource BoolToTextConverter}}" Clicked="UpdateDeliveryTimeClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}"></Button>

                                <StackLayout Orientation="Horizontal" HorizontalOptions="Center"
                                             HeightRequest="50">
                                        <Button Padding="10" Text="PROGRESS" Clicked="AuthorizedButton_OnClicked" CommandParameter="{Binding Key.TransactionGuid}" Style="{StaticResource ButtonStyle}"></Button>
                                    </StackLayout>
                                <Button Padding="10" Text="Show Instructions" Clicked="ShowInstructionsButton_OnClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}" IsVisible="{Binding Key.HasSpecialInstructions}"></Button>

                            </StackLayout>

                        </ViewCell>
                    </DataTemplate>
                </ListView.GroupHeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid
                            Padding="5"
                            ColumnSpacing="10"
                            RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name,StringFormat='Item Name: {0:F}'}" />
                                    <Label Text="{Binding Description,StringFormat='Description: {0:F}'}" />
                                    <Label Text="{Binding SizeName,StringFormat='Size: {0:F}'}" />
                                    <Label Text="{Binding OptionalChoices,StringFormat='Extras: {0:F}'}" IsVisible="{Binding OptionalChoicesEnabled}" />
                                    <Label Text="{Binding RequiredChoices,StringFormat='Included: {0:F}'}" IsVisible="{Binding RequiredChoicesEnabled}" />
                                    <Label IsVisible ="{Binding InstructionsEnabled}" Text="{Binding Instructions, StringFormat='Special Instructions: {0:F0}'}" />

                                    <Label Text="{Binding Quantity,StringFormat='Quantity: {0:N0}'}"/>
                                    <Label Text="{Binding Price,StringFormat='Price: {0:C}'}"/>
                                    <BoxView    Margin="0,10,0,0"
                                                VerticalOptions="Center"
                                                HorizontalOptions="FillAndExpand"
                                                HeightRequest="1"
                                                Color="Gray"></BoxView>
                                </StackLayout>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView x:Name="KitchenList" 
                  ItemsSource="{Binding KitchenPaymentsGrouped}" 
                  IsGroupingEnabled="True"
                  HasUnevenRows="True" Grid.Row="1" Grid.Column="1" SelectionMode="None" SeparatorVisibility="None" >
                <ListView.GroupHeaderTemplate>
                    <DataTemplate>
                        <ViewCell >
                            <ViewCell.Height>
                                <OnPlatform x:TypeArguments="x:Double" iOS="400" />
                            </ViewCell.Height>
                            <StackLayout Grid.Column="0" Grid.Row="0" Orientation="Vertical"
                            VerticalOptions="FillAndExpand"
                                     Padding="10"
                                     BackgroundColor="#3498DB" >

                                    <Label Text="{Binding Key.Name,StringFormat='Name: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.PhoneNumber,StringFormat='Phonenumber: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.Address1,StringFormat='Address: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.City,StringFormat='City: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.ZipCode,StringFormat='ZipCode: {0:F0}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.Total,StringFormat='SubTotal: {0:C}'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.Date,StringFormat='Order Time: {0:h:mm tt }'}" TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="{Binding Key.IsDelivery,StringFormat='Is Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.NoContact,StringFormat='Is No Contact Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Button Text="{Binding Key, Converter={StaticResource BoolToTextConverter}}" Clicked="UpdateDeliveryTimeClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}"></Button>

                                    <StackLayout Orientation="Horizontal" HorizontalOptions="Center"
                                             HeightRequest="50">
                                        <Button Text="REVERT" Clicked="KitchenBackButton_OnClicked" CommandParameter="{Binding Key.TransactionGuid}" Style="{StaticResource ButtonStyle}"></Button>
                                        <Button Text="PROGRESS" Clicked="KitchenButton_OnClicked" CommandParameter="{Binding Key.TransactionGuid}" Style="{StaticResource ButtonStyle}"></Button>

                                    </StackLayout>
                                     <Button Padding="10" Text="Show Instructions" Clicked="ShowInstructionsButton_OnClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}" IsVisible="{Binding Key.HasSpecialInstructions}"></Button>

                            </StackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.GroupHeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>

                            <Grid
                            Padding="10"
                            ColumnSpacing="10"
                            RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name,StringFormat='Item Name: {0:F}'}" />
                                    <Label Text="{Binding Description,StringFormat='Description: {0:F}'}" />
                                    <Label Text="{Binding SizeName,StringFormat='Size: {0:F}'}" />
                                    <Label Text="{Binding OptionalChoices,StringFormat='OptionalChoices: {0:F}'}" IsVisible="{Binding OptionalChoicesEnabled}" />
                                    <Label Text="{Binding RequiredChoices,StringFormat='Required: {0:F}'}" IsVisible="{Binding RequiredChoicesEnabled}" />
                                    <Label IsVisible ="{Binding InstructionsEnabled}" Text="{Binding Instructions, StringFormat='Special Instructions: {0:F0}'}" />
                                    <Label Text="{Binding Quantity,StringFormat='Quantity: {0:N0}'}"/>
                                    <Label Text="{Binding Price,StringFormat='Price: {0:C}'}"/>
                                </StackLayout>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <ListView x:Name="OutList" 
                  ItemsSource="{Binding OutPaymentsGrouped}" 
                  IsGroupingEnabled="True"
                  HasUnevenRows="True" Grid.Row="1" Grid.Column="2" SelectionMode="None" SeparatorVisibility="None">
                <ListView.GroupHeaderTemplate>
                    <DataTemplate>
                        <ViewCell >
                                                                                    <ViewCell.Height>
                                <OnPlatform x:TypeArguments="x:Double" iOS="400" />
</ViewCell.Height>
                            <StackLayout Orientation="Vertical"
                            VerticalOptions="FillAndExpand"
                                     Padding="10"
                                     BackgroundColor="#3498DB">
                                <Label Text="{Binding Key.Name,StringFormat='Name: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.PhoneNumber,StringFormat='Phonenumber: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.Address1,StringFormat='Address: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.City,StringFormat='City: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.ZipCode,StringFormat='ZipCode: {0:F0}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.Total,StringFormat='SubTotal: {0:C}'}" TextColor="White" VerticalOptions="Center"/>

                                <Label Text="{Binding Key.Date,StringFormat='Order Time: {0:h:mm tt }'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.IsDelivery,StringFormat='Is Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.NoContact,StringFormat='Is No Contact Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Button Text="{Binding Key, Converter={StaticResource BoolToTextConverter}}" Clicked="UpdateDeliveryTimeClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}"></Button>
                                <StackLayout Orientation="Horizontal"
                                             HorizontalOptions="Center">
                                    <Button HorizontalOptions="Start" Text="REVERT" Clicked="OutBackButton_OnClicked" CommandParameter="{Binding Key.TransactionGuid}" Style="{StaticResource ButtonStyle}"></Button>
                                    <Button HorizontalOptions="End" Text="PROGRESS" Clicked="OutButton_OnClicked" CommandParameter="{Binding Key.TransactionGuid}" Style="{StaticResource ButtonStyle}"></Button>

                                </StackLayout>
                                <Button Padding="10" Text="Show Instructions" Clicked="ShowInstructionsButton_OnClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}" IsVisible="{Binding Key.HasSpecialInstructions}"></Button>

                            </StackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.GroupHeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid
                            Padding="10"
                            ColumnSpacing="10"
                            RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name,StringFormat='Item Name: {0:F}'}" />
                                    <Label Text="{Binding Description,StringFormat='Description: {0:F}'}" />
                                    <Label Text="{Binding SizeName,StringFormat='Size: {0:F}'}" />
                                    <Label Text="{Binding OptionalChoices,StringFormat='OptionalChoices: {0:F}'}" IsVisible="{Binding OptionalChoicesEnabled}" />
                                    <Label Text="{Binding RequiredChoices,StringFormat='Required: {0:F}'}" IsVisible="{Binding RequiredChoicesEnabled}" />
                                    <Label IsVisible ="{Binding InstructionsEnabled}" Text="{Binding Instructions, StringFormat='Special Instructions: {0:F0}'}" />
                                    <Label Text="{Binding Quantity,StringFormat='Quantity: {0:N0}'}"/>
                                    <Label Text="{Binding Price,StringFormat='Price: {0:C}'}"/>
                                </StackLayout>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>


            <ListView x:Name="DeliveredList" 
                  ItemsSource="{Binding DeliveredPaymentsGrouped}" 
                  IsGroupingEnabled="True"
                  HasUnevenRows="True" Grid.Row="1" Grid.Column="3"
                  SelectionMode="None" SeparatorVisibility="None">

                <ListView.GroupHeaderTemplate>
                    <DataTemplate>
                        <ViewCell >
                                                                                    <ViewCell.Height>
                                <OnPlatform x:TypeArguments="x:Double" iOS="400" />
</ViewCell.Height>
                            <StackLayout Orientation="Vertical"
                            VerticalOptions="FillAndExpand"
                                     Padding="10"
                                     BackgroundColor="#3498DB">
                                <Label Text="{Binding Key.Name,StringFormat='Name: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.PhoneNumber,StringFormat='Phonenumber: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.Address1,StringFormat='Address: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.City,StringFormat='City: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.ZipCode,StringFormat='ZipCode: {0:F0}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.Total,StringFormat='SubTotal: {0:C}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.Date,StringFormat='Order Time: {0:h:mm tt }'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.IsDelivery,StringFormat='Is Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Label Text="{Binding Key.NoContact,StringFormat='Is No Contact Delivery: {0:F}'}" TextColor="White" VerticalOptions="Center"/>
                                <Button Text="{Binding Key, Converter={StaticResource BoolToTextConverter}}" Clicked="UpdateDeliveryTimeClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}"></Button>

                                <StackLayout Orientation="Horizontal"
                                             HorizontalOptions="Center" >
                                    <Button Text="REVERT" Clicked="DeliveredBackButton_OnClicked" CommandParameter="{Binding Key.TransactionGuid}" Style="{StaticResource ButtonStyle}"></Button>

                                </StackLayout>
                                <Button Padding="10" Text="Show Instructions" Clicked="ShowInstructionsButton_OnClicked" CommandParameter="{Binding Key}" Style="{StaticResource ButtonStyle}" IsVisible="{Binding Key.HasSpecialInstructions}"></Button>

                            </StackLayout>
                        </ViewCell>
                    </DataTemplate>
                </ListView.GroupHeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <ViewCell>
                            <Grid

                            Padding="10"
                            ColumnSpacing="10"
                            RowSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name,StringFormat='Item Name: {0:F}'}" />
                                    <Label Text="{Binding Description,StringFormat='Description: {0:F}'}" />
                                    <Label Text="{Binding SizeName,StringFormat='Size: {0:F}'}" />
                                    <Label Text="{Binding OptionalChoices,StringFormat='OptionalChoices: {0:F}'}" IsVisible="{Binding OptionalChoicesEnabled}" />
                                    <Label Text="{Binding RequiredChoices,StringFormat='Required: {0:F}'}" IsVisible="{Binding RequiredChoicesEnabled}" />
                                    <Label IsVisible ="{Binding InstructionsEnabled}" Text="{Binding Instructions, StringFormat='Special Instructions: {0:F0}'}"  />
                                    <Label Text="{Binding Quantity,StringFormat='Quantity: {0:N0}'}"/>
                                    <Label Text="{Binding Price,StringFormat='Price: {0:C}'}"/>
                                </StackLayout>
                            </Grid>
                        </ViewCell>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </ContentPage.Content>
</ContentPage>