<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:dataControls="clr-namespace:Telerik.XamarinForms.DataControls;assembly=Telerik.XamarinForms.DataControls"
             xmlns:listView="clr-namespace:Telerik.XamarinForms.DataControls.ListView;assembly=Telerik.XamarinForms.DataControls"
             xmlns:primitives="clr-namespace:Telerik.XamarinForms.Primitives;assembly=Telerik.XamarinForms.Primitives"
             xmlns:input="clr-namespace:Telerik.XamarinForms.Input;assembly=Telerik.XamarinForms.Input"
             x:Class="JessesPizza.Views.ShoppingCartPage"
             Title="{Binding Title}">
    <Grid BackgroundColor="{DynamicResource backgroundColor}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width ="*"/>
            <ColumnDefinition Width ="*"/>
            <ColumnDefinition Width ="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height ="Auto"/>
            <RowDefinition Height ="Auto"/>
            <RowDefinition Height ="*" />
            <RowDefinition Height ="Auto" />
            <RowDefinition Height ="Auto" />
            <RowDefinition Height ="Auto" />
            <RowDefinition Height ="Auto" />
            <RowDefinition Height ="Auto" />
        </Grid.RowDefinitions>
        <Label Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" Text="{Binding Count, StringFormat='My Order {0} '}" FontSize="Title" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}"  HorizontalOptions="Center"  ></Label>
        <Label IsVisible="{Binding IsEmpty}" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Text ="Shopping cart is empty" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" HorizontalOptions="Center"  ></Label>

        <ActivityIndicator  Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" IsVisible="{Binding IsBusy}" IsRunning="{Binding IsBusy}" HorizontalOptions="CenterAndExpand" VerticalOptions="Start"></ActivityIndicator>
        <dataControls:RadListView  HeightRequest="{Binding listHeight}" BackgroundColor="{DynamicResource backgroundColor}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4"  Margin="0,0,0,0"  ItemsSource="{Binding ShoppingItems}" x:Name="shoppingListView" SelectionMode="None">
            <dataControls:RadListView.ItemTemplate>
                <DataTemplate>
                    <listView:ListViewTemplateCell >
                        <listView:ListViewTemplateCell.View>
                            <Frame CornerRadius="10" Padding="10" Margin="2"  BackgroundColor="{DynamicResource ListViewBackgroundColor}"   >
                                <Grid >
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width ="100"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height ="Auto"/>
                                        <RowDefinition Height ="Auto" />

                                    </Grid.RowDefinitions>
                                    <Label Margin="5,0,0,0" Grid.Row="0" Grid.Column="0" Text="{Binding Name}" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                                    <Label Margin="0,5,10,0"  Grid.Row="0" Grid.Column="1" HorizontalOptions="End"  Text="{Binding Price, StringFormat='{0:C}'}" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" VerticalOptions="Center" />
                                    <StackLayout  MinimumHeightRequest="75" BackgroundColor = "{DynamicResource ListViewBackgroundColor}" Grid.Row="1" Grid.Column="1"  Padding="0" Margin="0,0,5,0">
                                        <input:RadButton 
                                                 CommandParameter="{Binding Id}"        
                                                 x:Name="editButton" 
                                                         Text="EDIT"
                                                         
                                                        Style="{DynamicResource ButtonStyle}"
                                                         BorderThickness="2" 
                                                         Clicked="edit_button_Clicked"
                                                 />
                                        <input:RadButton Grid.Row="2" Grid.Column="1"
                                                         x:Name="deleteButton" 
                                                         CommandParameter="{Binding Id}"       
                                                         Text="DELETE"  
                                                         Style="{DynamicResource ButtonStyle}"
                                                         Clicked="delete_button_Clicked"/>

                                    </StackLayout>
                                    <StackLayout Grid.Row="1" Grid.Column="0"  Padding="0" Margin="5,0,0,0">

                                        <primitives:RadExpander   x:Name="expander" HeaderText="Show Details"  >
                                            <primitives:RadExpander.Header>
                                                <primitives:ExpanderHeader BackgroundColor="{DynamicResource backgroundColor}">
                                                    <Label Text="Details" TextColor="{DynamicResource TextPrimaryColor}" />
                                                </primitives:ExpanderHeader>
                                            </primitives:RadExpander.Header>
                                            <primitives:RadExpander.Content>
                                                <StackLayout Margin="5,0,0,5" >
                                                    <Label Text="{Binding Description, StringFormat='Description: {0:F0}'}" TextColor="{DynamicResource TextPrimaryColor}" />
                                                    <Label IsVisible ="{Binding RequiredChoicesEnabled}" Text="{Binding RequiredChoices, StringFormat='Included Items: {0:F0}'}" TextColor="{DynamicResource TextPrimaryColor}" />
                                                    <Label IsVisible ="{Binding OptionalChoicesEnabled}" Text="{Binding OptionalChoices, StringFormat='Extras: {0:F0}'}" TextColor="{DynamicResource TextPrimaryColor}" />
                                                    <Label IsVisible ="{Binding InstructionsEnabled}" Text="{Binding Instructions, StringFormat='Special Instructions: {0:F0}'}" TextColor="{DynamicResource TextPrimaryColor}" />
                                                    <Label Text="{Binding SizeName, StringFormat='Size: {0:F0}'}" TextColor="{DynamicResource TextPrimaryColor}" />
                                                    <Label Text="{Binding Quantity, StringFormat='Quantity: {0:F0}'}" TextColor="{DynamicResource TextPrimaryColor}" />
                                                </StackLayout>
                                            </primitives:RadExpander.Content>
                                        </primitives:RadExpander>
                                    </StackLayout>
                                </Grid>
                            </Frame>
                        </listView:ListViewTemplateCell.View>
                    </listView:ListViewTemplateCell>
                </DataTemplate>
            </dataControls:RadListView.ItemTemplate>
            <dataControls:RadListView.ItemStyle>
                <listView:ListViewItemStyle BackgroundColor="{DynamicResource backgroundColor}"
                                        TextCellTextColor="{DynamicResource TextPrimaryColor}"
                                        BorderColor="{DynamicResource TextPrimaryColor}"
                                        BorderWidth="0"
                                        BorderLocation="All"
                                            RelativeLayout.HeightConstraint="50"
                                         />
            </dataControls:RadListView.ItemStyle>
            
        </dataControls:RadListView>
        <Label Grid.Row ="4" Grid.Column="1" HorizontalOptions="StartAndExpand" FontSize="Small" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" Text ="SubTotal:"/>
        <Label Grid.Row ="4" Grid.Column="2" HorizontalOptions="EndAndExpand" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" Text ="{Binding SubTotal, StringFormat='{0:C}'}"></Label>

        <!--<Label Grid.Row ="4" Grid.Column="1" HorizontalOptions="StartAndExpand" FontSize="Small" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}" Text ="Delivery Fee:"></Label>
        <Label Grid.Row ="4" Grid.Column="2" HorizontalOptions="EndAndExpand" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}"  Text ="{Binding DeliveryCharge, StringFormat='{0:C}'}"></Label>-->

        <Label Grid.Row ="5" Grid.Column="1" HorizontalOptions="StartAndExpand" FontSize="Small" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}"  Text ="Sales Tax:"></Label>
        <Label Grid.Row ="5" Grid.Column="2" HorizontalOptions="EndAndExpand" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}"  Text ="{Binding TaxTotal, StringFormat='{0:C}'}"></Label>

        <Label Grid.Row ="6" Grid.Column="1" HorizontalOptions="StartAndExpand" FontSize="Small" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}"  Text ="Order Total:"></Label>
        <Label Grid.Row ="6" Grid.Column="2" HorizontalOptions="EndAndExpand" FontSize="Medium" FontAttributes="Bold" TextColor="{DynamicResource TextPrimaryColor}"  Text ="{Binding Total, StringFormat='{0:C}'}"></Label>
        <input:RadButton  Grid.Row="7" Grid.Column="1"  Grid.ColumnSpan="2" 
                              x:Name="checkoutButton" 
                              Text="CHECKOUT"  
                                Style="{DynamicResource ButtonStyle}"
                                BorderWidth="3"
                              Clicked="checkout_button_Clicked">
            <input:RadButton.Margin>
                <OnPlatform x:TypeArguments="Thickness">
                    <On Platform="iOS" Value="0,0,0,25" />
                    <On Platform="Android, UWP" Value="0,0,0,10" />
                </OnPlatform>
            </input:RadButton.Margin>
        </input:RadButton>
    </Grid>
</ContentPage>