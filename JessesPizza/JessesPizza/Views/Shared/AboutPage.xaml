<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="JessesPizza.Views.AboutPage"
             xmlns:vm="clr-namespace:JessesPizza.ViewModels"
             Title="About Jesse's Pizza">

    <ContentPage.BindingContext>
        <vm:AboutViewModel />
    </ContentPage.BindingContext>

    <ContentPage.Resources>
        <ResourceDictionary>
            <!--Page Level Resources: Compatible with Xamarin Live Player -->
            <Color x:Key="Primary">#930304</Color>
            <Color x:Key="Accent">#E5DECC</Color>
            <Color x:Key="LightTextColor">#F8F7EF</Color>
            <Color x:Key="DarkAccent">#EDE7D7</Color>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid  BackgroundColor="{DynamicResource ListViewBackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackLayout BackgroundColor="{StaticResource Primary}" VerticalOptions="FillAndExpand" HorizontalOptions="Fill" >
            <StackLayout Margin="5,0,5,0" Orientation="Horizontal" HorizontalOptions="Center" VerticalOptions="Center" >
                <ContentView Padding="0,40,0,40" VerticalOptions="FillAndExpand" >
                    <Image Source="jessespizza.png" VerticalOptions="FillAndExpand" HeightRequest="100" Aspect ="AspectFill"/>
                </ContentView>
            </StackLayout>
        </StackLayout>
        <ScrollView Grid.Row="1" BackgroundColor="{DynamicResource ListViewBackgroundColor}">
            <StackLayout Orientation="Vertical" Padding="16,40,16,40" Spacing="10">
                <Label FontSize="22">
                    <Label.FormattedText>
                        <FormattedString>
                            <FormattedString.Spans>
                                <Span Text="About Jesse's Pizza" TextColor="{DynamicResource TextPrimaryColor}" FontAttributes="Bold" FontSize="22" />
                                <!--<Span Text=" " />
                                <Span Text="1.0" ForegroundColor="{StaticResource LightTextColor}" />-->
                            </FormattedString.Spans>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label>
                    <Label.FormattedText>
                        <FormattedString>
                            <FormattedString.Spans>
                                <Span Text="{Binding AboutString}" TextColor="{DynamicResource TextPrimaryColor}" FontAttributes="Italic" FontSize="18"/>
                            </FormattedString.Spans>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Button Margin="0,10,0,0" Text="Learn more"
                        Command="{Binding OpenWebCommand}"
                        Style="{DynamicResource ButtonStyle}"
                        TextColor="White" />
            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>