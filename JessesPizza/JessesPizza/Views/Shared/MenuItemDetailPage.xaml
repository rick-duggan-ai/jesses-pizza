<?xml version="1.0" encoding="utf-8"?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             xmlns:dataControls="clr-namespace:Telerik.XamarinForms.DataControls;assembly=Telerik.XamarinForms.DataControls"
             xmlns:listView="clr-namespace:Telerik.XamarinForms.DataControls.ListView;assembly=Telerik.XamarinForms.DataControls" 
             xmlns:input="clr-namespace:Telerik.XamarinForms.Input;assembly=Telerik.XamarinForms.Input" 
             xmlns:primitives="clr-namespace:Telerik.XamarinForms.Primitives;assembly=Telerik.XamarinForms.Primitives" 
             xmlns:local1="clr-namespace:JessesPizza.Styles" xmlns:helpers="clr-namespace:JessesPizza.Helpers" 
             xmlns:ffimageloading="clr-namespace:FFImageLoading.Forms;assembly=FFImageLoading.Forms" 
             x:Class="JessesPizza.Views.MenuItemDetailPage" 
            xmlns:ios="clr-namespace:Xamarin.Forms.PlatformConfiguration.iOSSpecific;assembly=Xamarin.Forms.Core" xmlns:animations="clr-namespace:JessesPizza.Animations"
             ios:Page.UseSafeArea="true"

             Title="{Binding Title}"
             BackgroundColor="{DynamicResource backgroundColor}">

    <ContentPage.Resources>
        <ResourceDictionary>

            <helpers:IdToGroupConverter x:Key="IdToGroupConverter" />
            <helpers:GroupImageConverter x:Key="GroupImageConverter" />
            <DataTemplate x:Key="ListViewGroupHeaderTemplate">
                <Grid >
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"></RowDefinition>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40"></ColumnDefinition>
                        <ColumnDefinition Width="Auto"></ColumnDefinition>
                        <ColumnDefinition Width="*"></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <ffimageloading:CachedImage Grid.Column="1" Source="{Binding Key, Converter={StaticResource GroupImageConverter}}" CacheDuration="50" RetryCount="3" RetryDelay="600" DownsampleToViewSize="true" HeightRequest="30" WidthRequest="30" Margin="5,5,0,5" />
                    <Label Style="{DynamicResource DescriptionStyle}" FontAttributes="Bold"  Grid.Column="2" VerticalOptions="Center" Text="{Binding Key, Converter={StaticResource IdToGroupConverter}}" />
                    <Label Grid.Column="0" TextColor="{DynamicResource TextPrimaryColor}" Margin="0,0,5,0" FontSize="Title" VerticalOptions="Center" HorizontalOptions="End" FontFamily="{StaticResource MaterialFontFamily}" Text="&#xf059;">
                        <Label.Triggers>
                            <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="True">
                                <Setter Property="Text" Value="&#xf04A;" />
                            </DataTrigger>
                            <DataTrigger TargetType="Label" Binding="{Binding IsExpanded}" Value="False">
                                <Setter Property="Text" Value="&#xf059;" />
                            </DataTrigger>
                        </Label.Triggers>
                    </Label>

                </Grid>
            </DataTemplate>

            <DataTemplate x:Key="FooterTemplate">
                <Grid Margin="5,0,5,0" BackgroundColor="{DynamicResource backgroundColor}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Frame Margin="0,10,0,0" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" BackgroundColor="{DynamicResource backgroundColor}">
                        <Editor Style="{DynamicResource EditorStyle}" AutoSize="TextChanges" Placeholder="Tap to add special instructions" Margin="5" x:Name="instructions" Text="{Binding SpecialInstructions}"  />
                    </Frame>
                    <input:RadButton Margin="0,0,0,40" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" x:Name="button" Text="{Binding ButtonText}" Style="{DynamicResource ButtonStyle}" BorderThickness="3" Clicked="AddToCartButton_Clicked"></input:RadButton>
                </Grid>
            </DataTemplate>
            
            <Style x:Key="DescriptionStyle" TargetType="Label">
                <Setter Property="FontSize">
                    <Setter.Value>
                        <OnPlatform
                            x:TypeArguments="x:Double"
                            Android="15"
                            iOS="20"
                            WinPhone="20" />
                    </Setter.Value>
                </Setter>
                <!--<Setter Property="Padding" Value="0,0,15,0"></Setter>-->
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
                <!--<Setter Property="FontFamily" Value="pizzaFont" />-->
            </Style>
            <Style x:Key="GroupItemTextStyle" TargetType="Label">
                <Setter Property="FontSize">
                    <Setter.Value>
                        <OnPlatform
                            x:TypeArguments="x:Double"
                            Android="15"
                            iOS="14"
                            WinPhone="20" />
                    </Setter.Value>
                </Setter>
                <!--<Setter Property="Padding" Value="0,0,10,0"> </Setter>-->
                <Setter Property="LineBreakMode" Value="CharacterWrap"></Setter>
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>
            <Style x:Key="RemoveItemTextStyle" TargetType="Label">
                <Setter Property="FontSize">
                    <Setter.Value>
                        <OnPlatform
                            x:TypeArguments="x:Double"
                            Android="15"
                            iOS="11"
                            WinPhone="20" />
                    </Setter.Value>
                </Setter>
                <!--<Setter Property="Padding" Value="0,0,10,0"> </Setter>-->
                <Setter Property="LineBreakMode" Value="CharacterWrap"></Setter>
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
            </Style>
            <Style x:Key="EditorStyle" TargetType="Editor">
                <Setter Property="FontSize">
                    <Setter.Value>
                        <OnPlatform
                            x:TypeArguments="x:Double"
                            Android="15"
                            iOS="16"
                            WinPhone="20" />
                    </Setter.Value>
                </Setter>
                <Setter Property="TextColor" Value="{StaticResource TextPrimaryColor}" />
                 
                <Setter Property="BackgroundColor" Value="{DynamicResource backgroundColor}"></Setter>
                <Setter Property="PlaceholderColor" Value="{DynamicResource TextPrimaryColor}"></Setter>
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <dataControls:RadListView Grid.Row="0"  IsVisible="{Binding ListEmpty, Converter={helpers:InverseBoolConverter}}"  HorizontalOptions="FillAndExpand" BackgroundColor="{DynamicResource backgroundColor}" 
                                 ItemTapped="listView_ItemTapped" x:Name="listView" ItemsSource="{Binding AllGroupItems}" SelectionMode="None" 
                                 FooterTemplate="{StaticResource FooterTemplate}" GroupHeaderTemplate="{StaticResource ListViewGroupHeaderTemplate}">
            <dataControls:RadListView.VerticalOptions>
                <OnPlatform x:TypeArguments="LayoutOptions">
                    <On Platform="Android" Value="FillAndExpand" />
                    <On Platform="iOS" Value="StartAndExpand" />
                </OnPlatform>
            </dataControls:RadListView.VerticalOptions>
            <dataControls:RadListView.LayoutDefinition>
                <listView:ListViewLinearLayout VerticalItemSpacing="2" >
                </listView:ListViewLinearLayout>
            </dataControls:RadListView.LayoutDefinition>
            <dataControls:RadListView.ItemStyle>
                <listView:ListViewItemStyle BackgroundColor="{DynamicResource backgroundColor}"
                                        TextCellTextColor="{DynamicResource TextPrimaryColor}"
                                        BorderColor="{DynamicResource TextPrimaryColor}"
                                        BorderWidth="0"
                                        BorderLocation="All" />
            </dataControls:RadListView.ItemStyle>

            <dataControls:RadListView.HeaderTemplate  >
                <DataTemplate >
                    <Grid Margin="0,0,0,10" BackgroundColor="{DynamicResource backgroundColor}" >
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Style="{DynamicResource TitleStyle}" FontSize="Title"  Margin="10,0,10,0" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" HorizontalOptions="Center" HorizontalTextAlignment="Center" Text="{Binding Title}" />
                        <Frame  IsVisible="{Binding ImageHasValue}" Margin="0" Padding="0" IsClippedToBounds="True" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" HeightRequest="100" WidthRequest="100" CornerRadius="10" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" >
                            <ffimageloading:CachedImage   HeightRequest="100" WidthRequest="100" Aspect="AspectFill" HorizontalOptions="FillAndExpand"  Source="{Binding Item.ImageUrl}" CacheDuration="50" RetryCount="3" RetryDelay="600" DownsampleToViewSize="true" />
                        </Frame>
                        <Label Text="{Binding Item.Description}"  Style="{DynamicResource DescriptionStyle}"  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="10,0,0,0"  HorizontalOptions="CenterAndExpand" HorizontalTextAlignment="Center" />
                        <Label  Text="{Binding Total, StringFormat='{0:C}'}" Style="{DynamicResource DescriptionStyle}"  Margin="10,0,0,0" Grid.Row="3" Grid.Column="0"  VerticalOptions="Center" />
                        <Stepper Grid.ColumnSpan="2" Grid.Row="3"  Grid.Column="1" x:Name="_stepper" Maximum="20" Minimum="1" Increment="1" HorizontalOptions="CenterAndExpand" ValueChanged="OnStepperValueChanged" Value="{Binding Quantity}" />
                        <Label  Text="{Binding Source={x:Reference _stepper}, Path=Value, StringFormat='Quantity:{0:F0}'}" Style="{DynamicResource DescriptionStyle}" Grid.Row="3" Grid.Column="3" VerticalOptions="Center"   HorizontalTextAlignment="Start"   >
                            <Label.Margin>
                                <OnPlatform x:TypeArguments="Thickness">
                                    <On Platform="iOS" Value="-20,0,5,0" />
                                    <On Platform="Android, WinPhone, Windows" Value="0,0,5,0" />
                                </OnPlatform>
                            </Label.Margin>
                        </Label>
                    </Grid>
                </DataTemplate>
            </dataControls:RadListView.HeaderTemplate>
            <dataControls:RadListView.GroupHeaderStyle>
                <listView:ListViewGroupStyle  BackgroundColor="#931303" TextColor="{DynamicResource TextPrimaryColor}" BorderColor="Black" BorderWidth="1" />
            </dataControls:RadListView.GroupHeaderStyle>
            <dataControls:RadListView.ItemTemplateSelector>
                <local1:CustomItemTemplateSelector>
                    
                    <local1:CustomItemTemplateSelector.NotSelectedTemplate >
                        <DataTemplate >
                            <listView:ListViewTemplateCell   >
                                <listView:ListViewTemplateCell.View >
                                    <Frame Margin="2" CornerRadius="10 " BackgroundColor="{DynamicResource ListViewBackgroundColor}"    >
                                        <Grid >
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"></RowDefinition>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                <ColumnDefinition Width="*"></ColumnDefinition>
                                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Grid.Row="0" HeightRequest="30" WidthRequest="30" Margin="10,5,0,0" Source="{Binding ImageUrl}"></Image>
                                            <Label  Style="{DynamicResource GroupItemTextStyle}" LineBreakMode="WordWrap"    Grid.Column="1" Grid.Row="0" Margin="0,5,0,0" Text="{Binding ItemName}" ></Label>
                                            <Label  Style="{DynamicResource GroupItemTextStyle}"  Grid.Column="2" Grid.Row="0" HorizontalOptions="End" Margin="0,5,15,0" Text="Tap to Add" ></Label>
                                        </Grid>
                                    </Frame>
                                </listView:ListViewTemplateCell.View>
                            </listView:ListViewTemplateCell>
                        </DataTemplate>
                    </local1:CustomItemTemplateSelector.NotSelectedTemplate>
                    
                    
                    <local1:CustomItemTemplateSelector.SizeAndSideTemplate>
                        <DataTemplate>
                            <listView:ListViewTemplateCell >
                                <listView:ListViewTemplateCell.View>
                                    <Frame Margin="2" BackgroundColor="{DynamicResource ListViewSelectedColor}" CornerRadius="10" >

                                        <Grid >
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"></RowDefinition>
                                                <RowDefinition Height="Auto"></RowDefinition>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" >
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>

                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Grid.Row="0" HeightRequest="30" WidthRequest="30" Margin="10,5,0,0" Source="{Binding ImageUrl}"></Image>
                                                <Label   Style="{DynamicResource GroupItemTextStyle}" Grid.Column="1" LineBreakMode="WordWrap" HorizontalOptions="Start"  VerticalTextAlignment="Start" Margin="0,5,0,5" HorizontalTextAlignment="Start" Text="{Binding ItemName}" ></Label>
                                                <Label WidthRequest="90" Style="{DynamicResource GroupItemTextStyle}" LineBreakMode="WordWrap" Grid.Column="2" HorizontalOptions="Start"  FontAttributes="Bold" HorizontalTextAlignment="Start" VerticalTextAlignment="Start"  Margin="0,5,0,5" Text="{Binding ItemPrice}" ></Label>
                                                <Label WidthRequest="100" Style="{DynamicResource RemoveItemTextStyle}" LineBreakMode="WordWrap" Grid.Column="3" HorizontalTextAlignment="End" VerticalTextAlignment="Start"  Margin="0,5,10,5" Text="Tap to Remove"></Label>

                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="50"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                                    <ColumnDefinition Width="50"></ColumnDefinition>

                                                    <ColumnDefinition Width="50"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                                    <ColumnDefinition Width="50"></ColumnDefinition>
                                                </Grid.ColumnDefinitions>
                                                <ImageButton Aspect="AspectFit" Grid.Column="0" Grid.Row="0" Margin="0,0,0,0" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand"  HeightRequest="40" WidthRequest="40" BackgroundColor="Transparent" Source="minus.png" IsEnabled="{Binding SideDecreaseEnable}" Command="{Binding DecreaseSide}" IsVisible="{Binding SideListFull}"></ImageButton>
                                                <Label  Style="{DynamicResource RemoveItemTextStyle}"    LineBreakMode="WordWrap" Grid.Column="1" Grid.Row="0" HorizontalTextAlignment="Center" Text="{Binding SideLabelText}"  IsVisible="{Binding SideListFull}"></Label>
                                                <ImageButton Aspect="AspectFit" Grid.Column="2" Grid.Row="0" Margin="0,0,5,0" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand"    HeightRequest="40" WidthRequest="40" BackgroundColor="Transparent" Source="plus.png"  IsEnabled="{Binding SideIncreaseEnable}" Command="{Binding IncreaseSide}" IsVisible="{Binding SideListFull}"></ImageButton>

                                                <ImageButton Aspect="AspectFit" Grid.Column="3" Grid.Row="0" Margin="5,0,0,0"  VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand" HeightRequest="40" WidthRequest="40" BackgroundColor="Transparent" Source="minus.png" IsEnabled="{Binding SizeDecreaseEnable}" Command="{Binding DecreaseSize}" IsVisible="{Binding SizeListFull}"></ImageButton>
                                                <Label  Style="{DynamicResource RemoveItemTextStyle}" LineBreakMode="WordWrap"    Margin="-10,10,-10,10" Grid.Column="4" Grid.Row="0" HorizontalTextAlignment="Center" Text="{Binding SizeLabelText}" IsVisible="{Binding SizeListFull}" ></Label >
                                                <ImageButton Aspect="AspectFit" Grid.Column="5" Grid.Row="0" Margin="0,0,0,0" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand"  HeightRequest="40" WidthRequest="40"  BackgroundColor="Transparent" Source="plus.png"   IsEnabled="{Binding SizeIncreaseEnable}" Command="{Binding IncreaseSize}" IsVisible="{Binding SizeListFull}"></ImageButton>
                                            </Grid>
                                        </Grid>
                                    </Frame>
                                </listView:ListViewTemplateCell.View>
                            </listView:ListViewTemplateCell>
                        </DataTemplate>
                    </local1:CustomItemTemplateSelector.SizeAndSideTemplate>
                    
                    <!--SIZE ONLY TEMPLATE-->
                    
                    <local1:CustomItemTemplateSelector.SizeOnlyTemplate>
                        <DataTemplate>
                            <listView:ListViewTemplateCell  >
                                <listView:ListViewTemplateCell.View>
                                    <Frame Margin="2" BackgroundColor="{DynamicResource ListViewSelectedColor}" CornerRadius="10"  >

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"></RowDefinition>
                                                <RowDefinition Height="Auto"></RowDefinition>
                                            </Grid.RowDefinitions>
                                            <Grid Grid.Row="0" >
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>

                                                </Grid.ColumnDefinitions>
                                                <Image Grid.Column="0" Grid.Row="0" HeightRequest="30" WidthRequest="30" Margin="10,5,0,0" Source="{Binding ImageUrl}"></Image>
                                                <!--<Label  LineBreakMode="WordWrap"  Style="{DynamicResource GroupItemTextStyle}" HorizontalOptions="Start"  VerticalTextAlignment="Start" Margin="0,5,0,5" HorizontalTextAlignment="Start" Text="{Binding ItemName}" ></Label>-->
                                                <Label Style="{DynamicResource GroupItemTextStyle}" Grid.Column="1" Grid.Row="0"  LineBreakMode="WordWrap" HorizontalOptions="Start"  FontAttributes="Bold" HorizontalTextAlignment="Start" VerticalTextAlignment="Start"  Margin="0,5,0,5" Text="{Binding ItemPrice}" ></Label>


                                                <Label Padding="0" WidthRequest="100" Style="{DynamicResource RemoveItemTextStyle}" LineBreakMode="WordWrap"  Grid.Column="2" HorizontalTextAlignment="End" VerticalTextAlignment="Start"  Margin="0,5,10,5" Text="Tap to Remove"></Label>

                                            </Grid>
                                            <Grid Grid.Row="1">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*"></RowDefinition>
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>

                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                                    <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                </Grid.ColumnDefinitions>
                                                <ImageButton Aspect="AspectFit" Grid.Column="4" Margin="0,0,0,0"  VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand" HeightRequest="40" WidthRequest="40" BackgroundColor="Transparent" Source="minus.png" IsEnabled="{Binding SizeDecreaseEnable}" Command="{Binding DecreaseSize}" IsVisible="{Binding SizeListFull}"></ImageButton>
                                                <Label  Style="{DynamicResource RemoveItemTextStyle}" LineBreakMode="WordWrap" Margin="0,5,0,8" Grid.Column="5" HorizontalTextAlignment="Center" Text="{Binding SizeLabelText}" IsVisible="{Binding SizeListFull}" ></Label>
                                                <ImageButton Aspect="AspectFit" Grid.Column="6"  Margin="0,0,0,0" VerticalOptions="CenterAndExpand" HorizontalOptions="CenterAndExpand"  HeightRequest="40" WidthRequest="40"  BackgroundColor="Transparent" Source="plus.png"   IsEnabled="{Binding SizeIncreaseEnable}" Command="{Binding IncreaseSize}" IsVisible="{Binding SizeListFull}"></ImageButton>

                                            </Grid>


                                        </Grid>
                                    </Frame>
                                </listView:ListViewTemplateCell.View>
                            </listView:ListViewTemplateCell>
                        </DataTemplate>
                    </local1:CustomItemTemplateSelector.SizeOnlyTemplate>
                    <local1:CustomItemTemplateSelector.NoSizeOrSideTemplate>
                        <DataTemplate >
                            <listView:ListViewTemplateCell >
                                <listView:ListViewTemplateCell.View>
                                    <Frame  Margin="2" CornerRadius="10 " BackgroundColor="{DynamicResource ListViewSelectedColor}"    >
                                        <Grid >
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"></RowDefinition>
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                                <ColumnDefinition Width="*"></ColumnDefinition>
                                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                            </Grid.ColumnDefinitions>
                                            <Image Grid.Column="0" Grid.Row="0" HeightRequest="30" WidthRequest="30" Margin="10,5,0,0" Source="{Binding ImageUrl}"></Image>
                                            <Label   Style="{DynamicResource GroupItemTextStyle}"  Grid.Column="1" Grid.Row="0" Margin="0,5,0,0" Text="{Binding ItemName}" ></Label>
                                            <Label  Style="{DynamicResource GroupItemTextStyle}" Grid.Column="2" Grid.Row="0" HorizontalOptions="End" Margin="0,5,15,0" Text="Tap to Remove" ></Label>
                                        </Grid>
                                    </Frame>
                                </listView:ListViewTemplateCell.View>
                            </listView:ListViewTemplateCell>
                        </DataTemplate>
                    </local1:CustomItemTemplateSelector.NoSizeOrSideTemplate>
                </local1:CustomItemTemplateSelector>
            </dataControls:RadListView.ItemTemplateSelector>

        </dataControls:RadListView>

        <Grid Grid.Row="0"  Margin="0,0,0,10"  BackgroundColor="{DynamicResource backgroundColor}"  IsVisible="{Binding ListEmpty}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Label Style="{DynamicResource TitleStyle}" HorizontalTextAlignment="Center" FontSize="Title"    Margin="10,0,10,0" Grid.Row="0" Grid.Column="0"  Grid.ColumnSpan="4"  Text="{Binding Title}" />
            <Frame IsVisible="{Binding ImageHasValue}" Margin="0" Padding="0" IsClippedToBounds="True" VerticalOptions="FillAndExpand" HorizontalOptions="FillAndExpand" HeightRequest="100" WidthRequest="100" CornerRadius="10" Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="2" >
                <ffimageloading:CachedImage Aspect="AspectFill" HorizontalOptions="FillAndExpand"  Source="{Binding Item.ImageUrl}" CacheDuration="50" RetryCount="3" RetryDelay="600" DownsampleToViewSize="true" />
            </Frame>
            <Label  Style="{DynamicResource DescriptionStyle}" Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Margin="10,0,0,0"  HorizontalOptions="CenterAndExpand" Text="{Binding Item.Description}"  />
            <Label  Style="{DynamicResource DescriptionStyle}" Margin="10,0,0,0" Grid.Row="3" Grid.Column="0" Text="{Binding Total, StringFormat='{0:C}'}" VerticalOptions="Center" />
            <Stepper Grid.ColumnSpan="2" Grid.Row="3" Grid.Column="1" x:Name="_stepper" Maximum="20" Minimum="1" Increment="1" HorizontalOptions="CenterAndExpand" ValueChanged="OnStepperValueChanged" Value="{Binding Quantity}" />
            <Label  Text="{Binding Source={x:Reference _stepper}, Path=Value, StringFormat='Quantity:{0:F0}'}" Style="{DynamicResource DescriptionStyle}" Grid.Row="3" Grid.Column="3" VerticalOptions="Center"   HorizontalTextAlignment="Start"   >
                <Label.Margin>
                    <OnPlatform x:TypeArguments="Thickness">
                        <On Platform="iOS" Value="-20,0,5,0" />
                        <On Platform="Android, WinPhone, Windows" Value="0,0,5,0" />
                    </OnPlatform>
                </Label.Margin>
            </Label>
            <Frame Margin="5,10,5,0" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="4" BackgroundColor="{DynamicResource backgroundColor}">
                <Editor Style="{DynamicResource EditorStyle}" AutoSize="TextChanges" Placeholder="Tap to Add Special Instructions" Margin="5"  Grid.ColumnSpan="4" x:Name="instructions" Text="{Binding SpecialInstructions}"  />
            </Frame>
            <input:RadButton Margin="0,5,0,75" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" x:Name="button" Text="{Binding ButtonText}" Style="{DynamicResource ButtonStyle}" BorderThickness="3" Clicked="AddToCartButton_Clicked"></input:RadButton>
        </Grid>
    </Grid>
</ContentPage>
